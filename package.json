{
  "name": "mdnkit",
  "version": "1.0.0",
  "description": "AI-powered legacy application modernization toolkit - Analyze legacy JavaScript/TypeScript apps and generate IBM Bob Skills for automated modernization",
  "main": "./dist/cli.js",
  "bin": {
    "mdnkit": "./dist/cli.js"
  },
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsc && npm run copy-templates",
    "copy-templates": "node -e \"require('fs-extra').copySync('src/templates', 'dist/templates')\"",
    "build:watch": "tsc --watch",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "modernization",
    "legacy",
    "javascript",
    "typescript",
    "ibm-bob",
    "ai",
    "code-analysis",
    "refactoring"
  ],
  "author": "IBM Bob Hackathon Team",
  "license": "MIT",
  "dependencies": {
    "@babel/parser": "^7.23.0",
    "chalk": "^5.3.0",
    "commander": "^11.0.0",
    "fast-glob": "^3.3.0",
    "fs-extra": "^11.0.0",
    "handlebars": "^4.7.9",
    "ora": "^7.0.0",
    "semver": "^7.5.0"
  },
  "devDependencies": {
    "@types/babel__parser": "^7.1.0",
    "@types/fs-extra": "^11.0.0",
    "@types/handlebars": "^4.0.40",
    "@types/node": "^20.0.0",
    "@types/semver": "^7.5.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  }
}
